NEXT_PUBLIC_SITE_URL=https://nirogidhara.com
NIROGIDHARA_DB_PATH=./data/nirogidhara.sqlite
ADMIN_PASSWORD=change-this-long-password
CRON_SECRET=change-this-cron-secret

# Optional: social adapters mark posts as skipped until these are configured.
LINKEDIN_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
FACEBOOK_ACCESS_TOKEN=
YOUTUBE_ACCESS_TOKEN=

# Optional premium daily image generation.
# If absent or if the image API fails, the app falls back to original generated SVG artwork.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
